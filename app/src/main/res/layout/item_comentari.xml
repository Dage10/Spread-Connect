<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardBackgroundColor="@color/item_background"
        app:cardCornerRadius="0dp"
        app:strokeColor="@color/comment_stroke"
        app:strokeWidth="2dp"
        app:cardElevation="4dp"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imgAvatarUser"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/avatar"
                    android:contentDescription="Avatar"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tvUsuari"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Usuari"
                    android:textStyle="bold"
                    android:textColor="@color/text_on_item"/>

                <TextView
                    android:id="@+id/tvData"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2025-01-01"
                    android:textColor="@color/text_on_item"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/tvHora"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15:00"
                    android:textColor="@color/text_on_item"
                    android:textSize="12sp"
                    android:layout_marginStart="4dp"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tvContingut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contingut"
                android:textSize="16sp"
                android:textColor="@color/text_on_item"
                android:layout_marginTop="4dp"/>


            <ImageView
                android:id="@+id/imgComentari"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="400dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                android:contentDescription="Imatge del comentari"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="8dp">

                <ImageButton
                    android:id="@+id/btnLike"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/like"
                    android:background="@android:color/transparent"
                    app:tint="@color/text_on_item"
                    android:contentDescription="Like"/>

                <TextView
                    android:id="@+id/textLikeComptador"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@color/text_on_item"
                    android:text="0"
                    android:textSize="12sp"/>

                <ImageButton
                    android:id="@+id/btnDislike"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/dislike"
                    android:background="@android:color/transparent"
                    app:tint="@color/text_on_item"
                    android:layout_marginStart="12dp"
                    android:contentDescription="Dislike"/>

                <TextView
                    android:id="@+id/textDislikeComptador"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@color/text_on_item"
                    android:text="0"
                    android:textSize="12sp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <ImageButton
                    android:id="@+id/btnComentari"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/comentari"
                    android:background="@android:color/transparent"
                    app:tint="@color/text_on_item"
                    android:contentDescription="Comentari"/>

                <ImageButton
                    android:id="@+id/btnBookmark"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/bookmark"
                    android:background="@android:color/transparent"
                    app:tint="@color/text_on_item"
                    android:layout_marginStart="8dp"
                    android:contentDescription="BookMark"/>

                <ImageButton
                    android:id="@+id/btnCompartir"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/compartir"
                    android:background="@android:color/transparent"
                    app:tint="@color/text_on_item"
                    android:layout_marginStart="8dp"
                    android:contentDescription="Compartir"/>

                <ImageButton
                    android:id="@+id/btnEditar"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/editar"
                    android:background="@android:color/transparent"
                    app:tint="@color/text_on_item"
                    android:layout_marginStart="8dp"
                    android:visibility="gone"
                    android:contentDescription="Editar"/>

                <ImageButton
                    android:id="@+id/btnEliminar"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/eliminar"
                    android:background="@android:color/transparent"
                    app:tint="@color/text_on_item"
                    android:layout_marginStart="8dp"
                    android:visibility="gone"
                    android:contentDescription="Eliminar"/>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>
