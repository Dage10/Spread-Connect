<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/app_background">

        <LinearLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@color/btn_chat"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btnEnrere"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/fletxa_enrere"
                android:contentDescription="Enrere"
                app:tint="@android:color/white"/>

            <ImageView
                android:id="@+id/imgAvatarUser"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:scaleType="centerCrop"
                android:src="@drawable/avatar"
                android:contentDescription="Avatar"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvNomUsuari"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvUltimaConnexio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:alpha="0.8"/>
            </LinearLayout>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMissatges"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:layout_constraintBottom_toTopOf="@id/inputLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <LinearLayout
            android:id="@+id/inputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="@color/item_background"
            android:gravity="center_vertical"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/btnEnviarImatge"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/afegir"
                android:contentDescription="Adjuntar imatge"
                android:background="@color/fons_boto_afegir"
                />

            <EditText
                android:id="@+id/etMissatge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Escriu un missatge..."
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:background="@android:color/transparent"/>

            <ImageButton
                android:id="@+id/btnEnviar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/enviar"
                android:background="@android:color/transparent"
                android:contentDescription="Enviar"
                app:tint="@color/btn_chat"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>